PORT=5000
FRONTEND_URL=http://localhost:5173

# Database configuration
MONGO_URI=mongodb://localhost:27017/diversifyai

# Authentication Secret (Used for JWT Tokens)
JWT_SECRET=your_jwt_secret_key_here

# Single admin configuration (used for admin login and advisor onboarding)
ADMIN_NAME=Platform Admin
ADMIN_EMAIL=admin@diversifyai.com
ADMIN_PASSWORD=change_this_admin_password

# AI Service Configuration
MEGALLM_API_KEY=your_megallm_api_key_here

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here